generator client {
  provider        = "prisma-client"
  previewFeatures = ["strictUndefinedChecks"]
  output          = "../src/generated/prisma"
  runtime         = "bun"
}

datasource db {
  provider = "sqlite"
}

model GuildSettings {
  id          String   @id
  adminRoleId String?
  mirrors     Mirror[]
}

model Mirror {
  id            String        @id
  channelAId    String
  channelBId    String
  guildId       String
  guildSettings GuildSettings @relation(fields: [guildId], references: [id])
}
